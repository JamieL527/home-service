generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SALES
  MARKETING
  DATA_COLLECTOR
  CONTRACTOR
}

enum LeadStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_FIX
  RESUBMITTED
  REJECTED
  CONVERTED
  NEW_LEAD
  BACKED
  URGENT
  PARKED
  SCHEDULED
  INJECTED
  MARKETING_INBOX
  TO_CONTACT
  CONTACTING
  NO_RESPONSE
  CONTACT_ESTABLISHED
  QUALIFIED
  JOB_ACTIVE
}

enum JobStatus {
  PENDING
  READY
  OFFER_SENT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  VERIFIED
  CANCELLED
}

enum ContractorCompanyStatus {
  UNVERIFIED_PROFILE
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  ACTION_REQUIRED
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  role                Role
  firstName           String?
  lastName            String?
  contractorCompanyId String?
  contractorCompany   ContractorCompany? @relation(fields: [contractorCompanyId], references: [id])
  zoneId              String?
  zone                Zone?              @relation(fields: [zoneId], references: [id])
  invitedAt           DateTime?
  createdAt           DateTime           @default(now())
}

model ContractorCompany {
  id              String                  @id @default(uuid())
  name            String
  status          ContractorCompanyStatus @default(UNVERIFIED_PROFILE)
  businessNumber  String?
  address         String?
  website         String?
  tradeType       String?
  wsibNumber      String?
  insuranceNumber String?
  contactName     String?
  contactTitle    String?
  contactEmail    String?
  contactPhone    String?
  termsAccepted   Boolean                 @default(false)
  termsAcceptedAt DateTime?
  adminNote       String?
  users           User[]
  jobs            Job[]
  offers          JobOffer[]
  createdAt       DateTime                @default(now())
}

model Lead {
  id             String     @id @default(uuid())
  address        String
  lat            Float?
  lng            Float?
  status         LeadStatus @default(DRAFT)
  source         String?
  phase          String?
  initialComment String?
  createdById    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  businessName   String?
  officeLocation String?
  rating         String?
  website        String?

  cityData       Json?
  photos         Json?
  ocrData        Json?

  zoneId            String?
  zoneName          String?
  isUrgent          Boolean   @default(false)
  scheduledInjectAt DateTime?
  reviewComment     String?
  submittedAt       DateTime?
  marketingTag      String?
  retryCount        Int       @default(0)
  nextFollowUpDate  DateTime?
  marketingNote     String?
  sentimentTag      String?

  contacts       LeadContact[]
  suppliers      LeadSupplier[]
  jobs           Job[]
  deals          Deal[]
}

model LeadSupplier {
  id             String  @id @default(uuid())
  leadId         String
  lead           Lead    @relation(fields: [leadId], references: [id])
  trade          String?
  company        String?
  contact        String?
  phone          String?
  email          String?
  website        String?
  officeLocation String?
  interaction    String?
}

model LeadContact {
  id     String  @id @default(uuid())
  leadId String
  lead   Lead    @relation(fields: [leadId], references: [id])
  name   String?
  email  String?
  phone  String?
  role   String?
}

model Job {
  id             String      @id @default(uuid())
  leadId         String
  lead           Lead        @relation(fields: [leadId], references: [id])
  phase          String?
  status         JobStatus   @default(PENDING)
  scope          String?
  priceType      String?
  priceFixed     Float?
  priceMin       Float?
  priceMax       Float?
  timeline       String?
  serviceType    String?
  contractorType String?
  companyId      String?
  company        ContractorCompany? @relation(fields: [companyId], references: [id])
  progressNote   String?
  progressPhotos Json?
  offers         JobOffer[]
  createdAt      DateTime    @default(now())
}

model JobOffer {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  companyId   String
  company     ContractorCompany @relation(fields: [companyId], references: [id])
  status      String            @default("pending")
  sentAt      DateTime          @default(now())
  respondedAt DateTime?
}


model Deal {
  id              String    @id @default(uuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id])
  projectName     String?
  clientName      String?
  projectType     String?
  phase           String?
  estimatedValue  Float?
  currentStage    String    @default("NEW_OPPORTUNITY")
  ownerId         String?
  status          String    @default("active")
  lossReason      String?
  notes           String?
  siteVisitDate   DateTime?
  deadline        DateTime?
  negotiationDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  quotes          Quote[]
}

model Quote {
  id          String    @id @default(uuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id])
  version     Int       @default(1)
  lineItems   Json?
  subtotal    Float?
  tax         Float?
  total       Float?
  status      String    @default("draft")
  notes       String?
  createdAt   DateTime  @default(now())
  submittedAt DateTime?
}

model Zone {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}
